{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "revenue-agent-platform",
  "main": "worker/revenue-agent-container.ts",
  "workers_dev": true,
  "compatibility_date": "2026-05-14",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "npm run build"
  },
  "triggers": {
    "crons": [
      "0 0 * * *"
    ]
  },
  "version_metadata": {
    "binding": "CF_VERSION_METADATA"
  },
  "containers": [
    {
      "class_name": "RevenueAgentContainer",
      "image": "./Dockerfile",
      "instance_type": "standard-1",
      "max_instances": 2
    }
  ],
  "ratelimits": [
    {
      "name": "REVENUE_AGENT_RUN_LIMITER",
      "namespace_id": "1002001",
      "simple": {
        "limit": 10,
        "period": 60
      }
    }
  ],
  "d1_databases": [
    {
      "binding": "OPERATIONAL_DB",
      "database_name": "revenue-agent-platform-operational",
      "database_id": "49141976-8515-4541-9bb0-ad8c4a4d1245"
    }
  ],
  "r2_buckets": [
    {
      "binding": "OPERATIONAL_ARTIFACTS",
      "bucket_name": "revenue-agent-platform-artifacts"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "REVENUE_AGENT_CONTAINER",
        "class_name": "RevenueAgentContainer"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "RevenueAgentContainer"
      ]
    }
  ],
  "vars": {
    "NODE_ENV": "production",
    "PORT": "3000",
    "DB_PATH": "/tmp/revenue-agent/pipeline.db",
    "OUTPUT_DIR": "/tmp/revenue-agent/proposals",
    "REVENUE_AGENT_RATE_LIMIT_PER_MINUTE": "60",
    "REVENUE_AGENT_ALLOW_EMAIL": "false",
    "REVENUE_AGENT_ALLOW_TELEGRAM": "false",
    "REVENUE_AGENT_ALLOW_PAYMENT_LINK": "false",
    "REVENUE_AGENT_CONTAINER_SLEEP_AFTER": "10m",
    "DURABLE_STORAGE_BASE_URL": "https://revenue-agent-platform.haruki-ito0044.workers.dev",
    "ARTIFACT_INLINE_BYTE_THRESHOLD": "16384",
    "REVENUE_AGENT_DISCOVERY_ENABLED": "false",
    "REVENUE_AGENT_DISCOVERY_DAILY_QUOTA": "3",
    "GEMINI_MODEL": "gemini-2.0-flash",
    "ZAI_BASE_URL": "https://api.z.ai/api/paas/v4",
    "ZAI_MODEL": "glm-4.5-flash",
    "SENDGRID_FROM_NAME": "RevenueAgentPlatform"
  },
  "secrets": {
    "required": [
      "REVENUE_AGENT_INTEGRATION_TOKEN",
      "FIRECRAWL_API_KEY",
      "GEMINI_API_KEY",
      "ADMIN_TOKEN",
      "DURABLE_STORAGE_TOKEN"
    ]
  }
}
