{
  "mcpServers": {
    "seo-outreach-pipeline": {
      "command": "node",
      "args": ["dist/mcp-server.js"],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}",
        "SENDGRID_API_KEY": "${SENDGRID_API_KEY}",
        "STRIPE_SECRET_KEY": "${STRIPE_SECRET_KEY}",
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}"
      }
    }
  },
  "agenticLoop": {
    "model": "claude-sonnet-4-6",
    "tools": [
      "crawl_sites",
      "score_seo",
      "filter_targets",
      "generate_proposal",
      "queue_outreach",
      "send_outreach",
      "notify_hil",
      "create_payment_link",
      "send_payment_link"
    ],
    "humanInTheLoop": {
      "approvalEndpoint": "${HIL_APPROVAL_BASE_URL}/hil/approve",
      "rejectionEndpoint": "${HIL_APPROVAL_BASE_URL}/hil/reject",
      "timeoutHours": 48,
      "notificationChannel": "${SLACK_CHANNEL_ID}"
    }
  }
}
