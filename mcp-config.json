{
  "mcpServers": {
    "seo-outreach-pipeline": {
      "command": "node",
      "args": ["dist/mcp-server.js"],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}",
        "SENDGRID_API_KEY": "${SENDGRID_API_KEY}",
        "SENDGRID_FROM_EMAIL": "${SENDGRID_FROM_EMAIL}",
        "SENDGRID_FROM_NAME": "${SENDGRID_FROM_NAME}",
        "STRIPE_SECRET_KEY": "${STRIPE_SECRET_KEY}",
        "STRIPE_WEBHOOK_SECRET": "${STRIPE_WEBHOOK_SECRET}",
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
        "SLACK_CHANNEL_ID": "${SLACK_CHANNEL_ID}",
        "GEMINI_API_KEY": "${GEMINI_API_KEY}",
        "ZAI_API_KEY": "${ZAI_API_KEY}",
        "HIL_APPROVAL_BASE_URL": "${HIL_APPROVAL_BASE_URL}",
        "HIL_APPROVAL_TOKEN_SECRET": "${HIL_APPROVAL_TOKEN_SECRET}"
      }
    }
  },
  "agenticLoop": {
    "model": "claude-sonnet-4-6",
    "tools": [
      "crawl_sites",
      "generate_proposals",
      "queue_outreach",
      "send_outreach",
      "create_payment_links",
      "get_pipeline_status"
    ],
    "humanInTheLoop": {
      "approvalEndpoint": "${HIL_APPROVAL_BASE_URL}/hil/approve",
      "rejectionEndpoint": "${HIL_APPROVAL_BASE_URL}/hil/reject",
      "timeoutHours": 48,
      "notificationChannel": "${SLACK_CHANNEL_ID}"
    }
  }
}
