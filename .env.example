# LLM providers (proposal generation)
# Gemini is used as primary (free tier available)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Z.ai GLM is used as fallback when Gemini quota is exceeded (optional)
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=glm-4.5-flash
# Anthropic API key (no longer required for proposal generation)
# ANTHROPIC_API_KEY=

# Firecrawl (site crawling)
FIRECRAWL_API_KEY=

# SendGrid (email outreach)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=

# Stripe (payment links)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Telegram (HIL/payment notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Admin operations dashboard
# Local/dev fallback for /admin when Cloudflare Access is not enabled.
ADMIN_TOKEN=

# Cloudflare Access
# Production should set CLOUDFLARE_ACCESS_ENABLED=true and configure the
# issuer/team domain plus audience tags from the Access applications.
CLOUDFLARE_ACCESS_ENABLED=false
CLOUDFLARE_ACCESS_ISSUER=
CLOUDFLARE_ACCESS_ADMIN_AUD=
CLOUDFLARE_ACCESS_MACHINE_AUD=
CLOUDFLARE_ACCESS_CERTS_URL=
CLOUDFLARE_ACCESS_ALLOW_ADMIN_TOKEN_FALLBACK=false
CLOUDFLARE_ACCESS_ALLOW_HUMAN_RUN_API=false
CLOUDFLARE_ACCESS_ALLOW_SERVICE_ADMIN=false

# HIL approval server
HIL_APPROVAL_BASE_URL=http://localhost:3000
HIL_APPROVAL_TOKEN_SECRET=
REVENUE_AGENT_INTEGRATION_TOKEN=
# RevenueAgentPlatform API security
# Keep side effects disabled unless production policy explicitly allows them.
REVENUE_AGENT_RATE_LIMIT_PER_MINUTE=60
REVENUE_AGENT_ALLOW_EMAIL=false
REVENUE_AGENT_ALLOW_TELEGRAM=false
REVENUE_AGENT_ALLOW_PAYMENT_LINK=false

# Daily target discovery job
# The cron job is deployed, but it is a no-op unless enabled.
REVENUE_AGENT_DISCOVERY_ENABLED=false
# Manual admin-button discovery is enabled unless explicitly set to false.
REVENUE_AGENT_DISCOVERY_MANUAL_ENABLED=true
REVENUE_AGENT_DISCOVERY_DAILY_QUOTA=3
# Comma- or newline-separated fixed candidates. Optional.
REVENUE_AGENT_DISCOVERY_SEED_URLS=
# Comma- or newline-separated search queries. Uses Firecrawl Search with FIRECRAWL_API_KEY.
REVENUE_AGENT_DISCOVERY_QUERIES=
REVENUE_AGENT_DISCOVERY_SEARCH_LIMIT=10
REVENUE_AGENT_DISCOVERY_SEARCH_COUNTRY=jp
REVENUE_AGENT_DISCOVERY_SEARCH_LANG=ja
REVENUE_AGENT_DISCOVERY_SEARCH_LOCATION=

# Pipeline config
SEO_SCORE_THRESHOLD=50
MAX_BATCH_SIZE=50
MAX_DAILY_EMAILS=50
OUTREACH_COOLDOWN_DAYS=30
# Optional. Required only when Chrome/Chromium is not in a standard path.
CHROME_PATH=

# Storage
DB_PATH=./data/pipeline.db
OUTPUT_DIR=./output/proposals

# E2E smoke validation
SMOKE_TARGET_URL=https://example.com
SMOKE_REPORT_DIR=./output/smoke-runs
# Side-effecting smoke steps are opt-in. Keep false unless using test accounts/channels.
SMOKE_SEND_EMAIL=false
SMOKE_EMAIL_TO=
SMOKE_SEND_TELEGRAM=false
SMOKE_CREATE_STRIPE_LINK=false
SMOKE_STRIPE_AMOUNT_JPY=100
