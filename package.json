{
  "name": "seo-outreach-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:server && npm run build:admin",
    "build:server": "tsc",
    "build:admin": "vite build --config admin-ui/vite.config.ts",
    "deploy:cloudflare": "wrangler deploy --containers-rollout immediate",
    "dev:cloudflare": "wrangler dev",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint .",
    "start": "node dist/server.js",
    "storage:export": "node scripts/export-operational-sqlite.mjs",
    "smoke:e2e": "tsx src/smoke/e2e-smoke.ts",
    "smoke:production": "node scripts/smoke-production.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.10.2",
    "@sendgrid/mail": "^8.1.3",
    "@sparticuz/chromium": "^131.0.1",
    "better-sqlite3": "^9.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firecrawl": "^1.16.4",
    "lighthouse": "^12.2.1",
    "md-to-pdf": "^5.2.4",
    "stripe": "^16.8.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/containers": "^0.0.24",
    "@cloudflare/workers-types": "^4.20250109.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "lucide-react": "^1.14.0",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.4.2",
    "vitest": "^1.6.0",
    "wrangler": "^4.81.0"
  }
}
